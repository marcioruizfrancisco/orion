# ============================================================
# Orion Project
#
# Arquivo:
#   .env.example
#
# Objetivo:
#   Modelo de configuração das variáveis de ambiente Orion.
#
# Observação:
#   Este arquivo deve ser copiado para:
#
#   .env
#
# Antes da execução das Stacks Docker.
#
# O arquivo .env contém valores específicos da instalação
# e não deve ser enviado ao Git.
#
# ============================================================


# ============================================================
# Projeto
# ============================================================

ORION_PROJECT_NAME=orion


# ============================================================
# Docker Network
# ============================================================

ORION_NETWORK=orion_network


# ============================================================
# PostgreSQL
# ============================================================

ORION_POSTGRES_CONTAINER=orion-postgres
ORION_POSTGRES_VOLUME=orion-postgres-data

ORION_POSTGRES_DB=orion
ORION_POSTGRES_USER=orion
ORION_POSTGRES_PASSWORD=change_me


# ============================================================
# Redis
# ============================================================

ORION_REDIS_CONTAINER=orion-redis
ORION_REDIS_VOLUME=orion-redis-data
